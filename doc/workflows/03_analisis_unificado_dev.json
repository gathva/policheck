                "options": {
                    "timeout": 60000
                }
            },
            "id": "gemma",
            "name": "Gemma 3",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.2,
            "position": [
                1340,
                300
            ],
            "notes": "Modelo Económico 2"
        },
        {
            "parameters": {
                "url": "https://openrouter.ai/api/v1/chat/completions",
                "authentication": "genericCredentialType",
                "genericAuthType": "httpHeaderAuth",
                "sendBody": true,
                "bodyParameters": {
                    "parameters": [
                        {
                            "name": "model",
                            "value": "google/gemini-2.5-flash-lite-preview-06-17"
                        },
                        {
                            "name": "messages",
                            "value": "=[{ \"role\": \"system\", \"content\": \"Eres un analista político imparcial. Analiza la siguiente fuente sobre un político chileno y evalúa: 1) Veracidad(0-100), 2) Coherencia(0-100), 3) Sesgo. Responde SOLO en JSON: {\\\"veracity_score\\\": number, \\\"coherence_score\\\": number, \\\"bias_analysis\\\": string, \\\"summary\\\": string, \\\"key_claims\\\": [string]}\" }, { \"role\": \"user\", \"content\": \"Título: \" + $json.title + \"\\n\\nContenido: \" + $json.extracted_text }]"
                        },
                        {
                            "name": "max_tokens",
                            "value": "=800"
                        }
                    ]
                },
                "options": {
                    "timeout": 60000
                }
            },
            "id": "flash-lite",
            "name": "Flash Lite",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.2,
            "position": [
                1340,
                500
            ],
            "notes": "Modelo Económico 3"
        },
        {
            "parameters": {
                "jsCode": "const items = $input.all();\nconst baseData = $('Unir Extracción').item.json;\nconst modelNames = ['openai/gpt-4o-mini', 'google/gemma-3-27b-it', 'google/gemini-2.5-flash-lite-preview-06-17'];\nconst results = [];\nlet totalVeracity = 0;\nlet validCount = 0;\n\nitems.forEach((item, index) => {\n  try {\n    const raw = item.json.choices?.[0]?.message?.content || '{}';\n    const parsed = JSON.parse(raw.replace(/```json\\n?|```/g, '').trim());\n    \n    results.push({\n      source_id: baseData.source_id,\n      model_name: modelNames[index] || `modelo_${index}`,\n      report_json: parsed,\n      summary: parsed.summary || '',\n      veracity_score: parsed.veracity_score || null\n    });\n    \n    if (parsed.veracity_score) {\n      totalVeracity += parsed.veracity_score;\n      validCount++;\n    }\n  } catch(e) {\n    console.log('Error parseando: ' + e.message);\n  }\n});\n\nconst avgVeracity = validCount > 0 ? (totalVeracity / validCount).toFixed(2) : null;\n\nreturn [{\n  json: {\n    reports: results,\n    source_id: baseData.source_id,\n    politician_id: baseData.politician_id,\n    avg_veracity: avgVeracity,\n    models_used: validCount,\n    title: baseData.title\n  }\n}];"
            },
            "id": "combine-analysis",
            "name": "Combinar Análisis",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                1560,
                300
            ]
        },
        {
            "parameters": {
                "url": "=https://alxidykzaoiupbnlxgcf.supabase.co/rest/v1/ai_reports",
                "sendHeaders": true,
                "headerParameters": {
                    "parameters": [
                        {
                            "name": "apikey",
                            "value": "={{ $env.SUPABASE_SERVICE_KEY }}"
                        },
                        {
                            "name": "Authorization",
                            "value": "=Bearer {{ $env.SUPABASE_SERVICE_KEY }}"
                        },
                        {
                            "name": "Content-Type",
                            "value": "application/json"
                        },
                        {
                            "name": "Prefer",
                            "value": "return=minimal"
                        }
                    ]
                },
                "sendBody": true,
                "bodyParameters": {
                    "parameters": [
                        {
                            "name": "",
                            "value": "={{ JSON.stringify($json.reports) }}"
                        }
                    ]
                },
                "options": {}
            },
            "id": "save-to-supabase",
            "name": "Guardar en Supabase",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.2,
            "position": [
                1780,
                300
            ]
        },
        {
            "parameters": {
                "respondWith": "json",
                "responseBody": "={{ JSON.stringify({ success: true, source_id: $json.source_id, avg_veracity: $json.avg_veracity, title: $json.title }) }}"
            },
            "id": "respond-ok",
            "name": "Responder a Next.js",
            "type": "n8n-nodes-base.respondToWebhook",
            "typeVersion": 1,
            "position": [
                2000,
