{
    "name": "PoliCheck - Workflow Unificado (Modo DEV)",
    "nodes": [
        {
            "parameters": {
                "httpMethod": "POST",
                "path": "policheck-process",
                "responseMode": "responseNode",
                "options": {}
            },
            "id": "webhook-trigger",
            "name": "Webhook: Iniciar Proceso",
            "type": "n8n-nodes-base.webhook",
            "typeVersion": 1.1,
            "position": [
                240,
                300
            ],
            "notes": "Recibe: { source_id, url, source_type, politician_id }"
        },
        {
            "parameters": {
                "conditions": {
                    "options": {
                        "caseSensitive": true
                    },
                    "conditions": [
                        {
                            "id": "youtube-check",
                            "leftValue": "={{ $json.body.url }}",
                            "rightValue": "youtube.com",
                            "operator": {
                                "type": "string",
                                "operation": "contains"
                            }
                        }
                    ]
                }
            },
            "id": "router-youtube",
            "name": "¿Es YouTube?",
            "type": "n8n-nodes-base.if",
            "typeVersion": 2,
            "position": [
                460,
                300
            ]
        },
        {
            "parameters": {
                "url": "=https://www.youtube.com/watch?v={{ $json.body.url.split('v=')[1] || $json.body.url.split('youtu.be/')[1] }}",
                "options": {
                    "response": {
                        "response": {
                            "responseFormat": "text"
                        }
                    }
                }
            },
            "id": "youtube-page-fetch",
            "name": "Obtener página YouTube",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.2,
            "position": [
                680,
                180
            ]
        },
        {
            "parameters": {
                "url": "={{ $('Webhook: Iniciar Proceso').item.json.body.url }}",
                "options": {
                    "response": {
                        "response": {
                            "responseFormat": "text"
                        }
                    },
                    "timeout": 30000
                }
            },
            "id": "article-fetch",
            "name": "Obtener Artículo HTML",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.2,
            "position": [
                680,
                420
            ]
        },
        {
            "parameters": {
                "jsCode": "const html = $input.first().json.data;\nconst titleMatch = html.match(/<title[^>]*>([^<]+)<\\/title>/i);\nconst title = titleMatch ? titleMatch[1].replace(' - YouTube', '').trim() : 'Video sin título';\nconst descMatch = html.match(/\"description\":{\"simpleText\":\"([^\"]+)\"/);\nconst description = descMatch ? descMatch[1].substring(0, 2000) : '';\n\nreturn [{\n  json: {\n    source_id: $('Webhook: Iniciar Proceso').item.json.body.source_id,\n    politician_id: $('Webhook: Iniciar Proceso').item.json.body.politician_id,\n    url: $('Webhook: Iniciar Proceso').item.json.body.url,\n    source_type: 'video_youtube',\n    title: title,\n    extracted_text: description || title,\n    char_count: (description || title).length\n  }\n}];"
            },
            "id": "parse-youtube",
            "name": "Parsear YouTube",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                900,
                180
            ]
        },
        {
            "parameters": {
                "jsCode": "const html = $input.first().json.data;\nconst titleMatch = html.match(/<title[^>]*>([^<]+)<\\/title>/i);\nconst h1Match = html.match(/<h1[^>]*>([^<]+)<\\/h1>/i);\nconst title = (titleMatch ? titleMatch[1] : (h1Match ? h1Match[1] : 'Sin título')).trim();\n\nlet text = html\n  .replace(/<script[^>]*>[\\s\\S]*?<\\/script>/gi, '')\n  .replace(/<style[^>]*>[\\s\\S]*?<\\/style>/gi, '')\n  .replace(/<nav[^>]*>[\\s\\S]*?<\\/nav>/gi, '')\n  .replace(/<header[^>]*>[\\s\\S]*?<\\/header>/gi, '')\n  .replace(/<footer[^>]*>[\\s\\S]*?<\\/footer>/gi, '')\n  .replace(/<[^>]+>/g, ' ')\n  .replace(/&nbsp;/g, ' ')\n  .replace(/&amp;/g, '&')\n  .replace(/\\s+/g, ' ')\n  .trim()\n  .substring(0, 8000);\n\nreturn [{\n  json: {\n    source_id: $('Webhook: Iniciar Proceso').item.json.body.source_id,\n    politician_id: $('Webhook: Iniciar Proceso').item.json.body.politician_id,\n    url: $('Webhook: Iniciar Proceso').item.json.body.url,\n    source_type: 'articulo_noticia',\n    title: title,\n    extracted_text: text,\n    char_count: text.length\n  }\n}];"
            },
            "id": "parse-article",
            "name": "Parsear Artículo",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                900,
                420
            ]
        },
        {
            "parameters": {},
            "id": "merge-extraction",
            "name": "Unir Extracción",
            "type": "n8n-nodes-base.merge",
            "typeVersion": 3,
            "position": [
                1120,
                300
            ]
        },
        {
            "parameters": {
                "url": "https://openrouter.ai/api/v1/chat/completions",
                "authentication": "genericCredentialType",
                "genericAuthType": "httpHeaderAuth",
                "sendBody": true,
                "bodyParameters": {
                    "parameters": [
                        {
                            "name": "model",
                            "value": "openai/gpt-4o-mini"
                        },
                        {
                            "name": "messages",
                            "value": "=[{ \"role\": \"system\", \"content\": \"Eres un analista político imparcial. Analiza la siguiente fuente sobre un político chileno y evalúa: 1) Veracidad(0-100), 2) Coherencia(0-100), 3) Sesgo. Responde SOLO en JSON: {\\\"veracity_score\\\": number, \\\"coherence_score\\\": number, \\\"bias_analysis\\\": string, \\\"summary\\\": string, \\\"key_claims\\\": [string]}\" }, { \"role\": \"user\", \"content\": \"Título: \" + $json.title + \"\\n\\nContenido: \" + $json.extracted_text }]"
                        },
                        {
                            "name": "max_tokens",
                            "value": "=800"
                        }
                    ]
                },
                "options": {
                    "timeout": 60000
                }
            },
            "id": "gpt4-mini",
            "name": "GPT-4o Mini",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.2,
            "position": [
                1340,
                100
            ],
            "notes": "Modelo Económico 1"
        },
        {
            "parameters": {
                "url": "https://openrouter.ai/api/v1/chat/completions",
                "authentication": "genericCredentialType",
                "genericAuthType": "httpHeaderAuth",
                "sendBody": true,
                "bodyParameters": {
                    "parameters": [
                        {
                            "name": "model",
                            "value": "google/gemma-3-27b-it"
                        },
                        {
                            "name": "messages",
                            "value": "=[{ \"role\": \"system\", \"content\": \"Eres un analista político imparcial. Analiza la siguiente fuente sobre un político chileno y evalúa: 1) Veracidad(0-100), 2) Coherencia(0-100), 3) Sesgo. Responde SOLO en JSON: {\\\"veracity_score\\\": number, \\\"coherence_score\\\": number, \\\"bias_analysis\\\": string, \\\"summary\\\": string, \\\"key_claims\\\": [string]}\" }, { \"role\": \"user\", \"content\": \"Título: \" + $json.title + \"\\n\\nContenido: \" + $json.extracted_text }]"
                        },
                        {
                            "name": "max_tokens",
                            "value": "=800"
                        }
                    ]
